# Copy to the repo root as `.env` on the GCP VM (the compose file reads it).
NODE_ENV=production
PORT=8080

# Your public HTTPS hostname (must match the Caddyfile). Used for the webhook
# + OAuth callback. e.g. a free DuckDNS subdomain pointed at the VM's static IP.
PUBLIC_URL=https://your-host.duckdns.org

# Neon free-tier Postgres POOLED connection string. SSL is auto-enabled for
# non-local hosts. (GCP's 1 GB VM can't also run Postgres, so the DB is external.)
DATABASE_URL=postgres://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/agentpr
# DATABASE_SSL=auto   # auto|require|no-verify|disable

# GitHub App (see SETUP.md)
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_PRIVATE_KEY=

# Only this GitHub login may sign in to the dashboard.
ALLOWED_GITHUB_LOGIN=your-github-login

# openssl rand -hex 32
SESSION_SECRET=
# openssl rand -hex 32  — your runner presents this once to enroll.
RUNNER_ENROLLMENT_SECRET=

# Optional: pause AUTO reviews once today's measured spend crosses this.
# GLOBAL_DAILY_COST_CAP_USD=5

# These vars configure the control plane.
#
# Cloud Run (primary, ~$0): you do NOT use this .env file. Non-secret vars are set
#   via `gcloud run deploy --set-env-vars` and secrets come from Secret Manager
#   (`--set-secrets`). See SETUP.md §4–§5. This file documents the full set.
# VM fallback: copy to the repo root as `.env` (the compose file reads it).
NODE_ENV=production
PORT=8080

# Public HTTPS base URL — used for the webhook + OAuth callback.
# Cloud Run: the *.run.app URL (set after the first deploy, SETUP.md §6).
# VM:        your DuckDNS hostname (must match the Caddyfile).
PUBLIC_URL=https://your-host.duckdns.org

# Neon free-tier Postgres POOLED connection string. SSL is auto-enabled for
# non-local hosts. (GCP's 1 GB VM can't also run Postgres, so the DB is external.)
DATABASE_URL=postgres://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/agentpr
# DATABASE_SSL=auto   # auto|require|no-verify|disable

# GitHub App (see SETUP.md)
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_PRIVATE_KEY=

# Only this GitHub login may sign in to the dashboard.
ALLOWED_GITHUB_LOGIN=your-github-login

# openssl rand -hex 32
SESSION_SECRET=
# openssl rand -hex 32  — your runner presents this once to enroll.
RUNNER_ENROLLMENT_SECRET=

# openssl rand -hex 32 — shared bearer secret for POST /internal/sweep.
# Required on Cloud Run (Cloud Scheduler sends it; the in-process timer is off there).
INTERNAL_API_TOKEN=

# Lease sweep timer. Leave unset/"true" on the VM (in-process timer runs).
# On Cloud Run set "false" — the frozen instance can't fire timers; Cloud
# Scheduler → POST /internal/sweep handles it instead.
# ENABLE_INPROCESS_SWEEP=true

# Optional: pause AUTO reviews once today's measured spend crosses this.
# GLOBAL_DAILY_COST_CAP_USD=5

# Copy to ~/.agentpr/runner.env on the machine where Claude is logged in.
# Read by the systemd unit.
#
# The runner runs directly on the host (not in Docker) so it can reach your Claude
# OAuth login (~/.claude/.credentials.json) and the claude binary.

# The control plane's PUBLIC URL (the GCP deployment). The runner dials OUT to this.
CONTROL_PLANE_URL=https://your-host.duckdns.org

RUNNER_NAME=my-runner

# Presented ONCE to enroll; after that the durable token is saved to RUNNER_CRED_FILE
# and this can be removed. Must equal the control plane's RUNNER_ENROLLMENT_SECRET.
RUNNER_ENROLLMENT_SECRET_CLIENT=

# Absolute path to the claude binary — it is NOT on the non-interactive PATH.
# Find it with:  zsh -lic 'command -v claude'   (e.g. /home/youruser/.local/bin/claude)
CLAUDE_BIN=/home/youruser/.local/bin/claude

RUNNER_WORKDIR=/home/youruser/.agentpr/work
RUNNER_CRED_FILE=/home/youruser/.agentpr/runner.json

# ⚠️ Do NOT set ANTHROPIC_API_KEY here. If set, claude bills the pay-per-token API
# instead of your subscription — the runner detects this and refuses to run.

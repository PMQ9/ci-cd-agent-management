# Copy to the repo root as `.env` on your self-hosted host (docker compose reads it).
NODE_ENV=production
PORT=8080

# The Tailscale Funnel URL (or your domain). Used for the webhook + OAuth callback.
PUBLIC_URL=https://your-host.tailXXXX.ts.net

# Inside docker compose, the DB host is the service name "postgres".
DATABASE_URL=postgres://agentpr:agentpr@postgres:5432/agentpr

# GitHub App (see SETUP.md to create it)
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=
# Paste the PEM with literal \n between lines, OR mount the file and use _PATH.
GITHUB_APP_PRIVATE_KEY=
# GITHUB_APP_PRIVATE_KEY_PATH=/run/secrets/github_app.pem

# Only this GitHub login may sign in to the dashboard.
ALLOWED_GITHUB_LOGIN=your-github-login

# openssl rand -hex 32
SESSION_SECRET=
# openssl rand -hex 32  — the runner presents this once to enroll.
RUNNER_ENROLLMENT_SECRET=

# Optional global spend guard: pause AUTO reviews once today's measured cost crosses this.
# GLOBAL_DAILY_COST_CAP_USD=5

# ─────────────────────────────────────────────────────────────────────────────
# Control plane (packages/control-plane) — runs on your self-hosted host in Docker
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080

# Public HTTPS URL the dashboard + GitHub reach (Tailscale Funnel *.ts.net, or
# https://smee.io/<id> proxied locally during dev). Used for webhook + OAuth callback.
PUBLIC_URL=http://localhost:8080

# Postgres (docker-compose default below)
DATABASE_URL=postgres://agentpr:agentpr@localhost:5432/agentpr

# GitHub App (create one, then fill these in). The SAME app does repo access AND login.
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=
# Private key PEM. Either inline (with literal \n) or point to a file via _PATH.
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_PATH=

# Dashboard auth: only this GitHub login may sign in (single-user allowlist).
ALLOWED_GITHUB_LOGIN=

# Signing secret for session cookies (generate: openssl rand -hex 32)
SESSION_SECRET=

# One-time bootstrap secret a new runner presents to enroll (generate: openssl rand -hex 32)
RUNNER_ENROLLMENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Runner (packages/runner) — runs on the HOST (systemd) where claude is logged in
# ─────────────────────────────────────────────────────────────────────────────
CONTROL_PLANE_URL=http://localhost:8080
RUNNER_NAME=my-runner
# Presented once to enroll; after enrollment the runner stores a durable token.
RUNNER_ENROLLMENT_SECRET_CLIENT=
# Absolute path to the claude binary (it is NOT on the non-interactive PATH on your self-hosted host).
CLAUDE_BIN=claude
# Where the runner checks out PRs (git worktrees)
RUNNER_WORKDIR=./.agentpr/work
# MUST stay unset, or claude bills the API instead of the subscription. The runner
# asserts this and refuses to run if it is set — do not define ANTHROPIC_API_KEY here.
